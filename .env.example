# ── Gemini AI (research + tweet generation) ─────────────────────────────────────
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Tavily (real-time web search for research) ───────────────────────────────────
# Get key: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx
# Optional: model name (default: gemini-3-flash-preview). Alternatives: gemini-2.0-flash, gemini-1.5-flash
# GEMINI_MODEL=gemini-3-flash-preview

# ── X (Twitter) API ────────────────────────────────────────────────────────────
# developer.x.com → Your App → Keys & Tokens
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_token_secret

# ── Email (approval links) ─────────────────────────────────────────────────────
# Gmail: myaccount.google.com/apppasswords (requires 2FA)
EMAIL_SENDER=your@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=your_personal@gmail.com

# ── Approval server (Flask) ────────────────────────────────────────────────────
# When running locally: http://localhost:5000
# On VPS: http://YOUR_VPS_IP:5000
SERVER_BASE_URL=http://localhost:5000

# ── Optional: topic niche for research (default: Tech & AI) ─────────────────────
# NICHE=Tech & AI

# ── Tweet card image (shown on card and in approval email) ─────────────────────
# X_HANDLE=@yourhandle

# ── Optional: post to X immediately without email approval ──────────────────────
# Set to 1 to skip approval email and post the generated tweet directly.
# POST_DIRECTLY=0
